{
  "metadata": {
    "project": "pbs-plus",
    "module": "github.com/pbs-plus/pbs-plus",
    "description": "Complete file-by-file mapping for domain-driven package restructure. Consolidates backend/, web/, store/, tasks/, application/ into internal/server/. Renames snake_case filenames to MixedCaps. Merges deep sub-packages to stay within 3 directory levels from internal/.",
    "constraints": [
      "Max 3 directory levels from internal/ root (internal/server/X/Y is the limit)",
      "sqlc-generated code structure preserved (files stay together at internal/server/database/sqlc/)",
      "Build constraint tags preserved in file content",
      "Test files stay with their source files",
      "Non-Go files (SQL, JS, PS1) move with their packages"
    ]
  },

  "domain_moves": {
    "description": "All files moving from old server packages into internal/server/",

