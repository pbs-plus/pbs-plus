  "merge_operations": {
    "description": "Packages merged into their parent to stay within 3-level depth limit. Requires: (1) change package declaration, (2) update internal references, (3) rename exported symbols if collisions exist.",
    "merges": [
      {
        "old_package": "internal/backend/rpc/job",
        "old_package_name": "job",
        "new_package": "internal/server/rpc",
        "new_package_name": "rpc",
        "files": [
          {
            "old_path": "internal/backend/rpc/job/service.go",
            "new_path": "internal/server/rpc/jobService.go"
          }
        ],
        "symbol_renames": {},
        "notes": "No exported symbol collisions. job.JobRPCService, job.BackupQueueArgs, etc. become rpc.JobRPCService, rpc.BackupQueueArgs."
      },
      {
        "old_package": "internal/backend/vfs/arpcfs/arpcfuse",
        "old_package_name": "arpcfuse",
        "new_package": "internal/server/vfs/arpcfs",
        "new_package_name": "arpcfs",
        "files": [
          {
            "old_path": "internal/backend/vfs/arpcfs/arpcfuse/server.go",
            "new_path": "internal/server/vfs/arpcfs/arpcfuse.go"
          }
        ],
        "symbol_renames": {
          "arpcfuse.Mount": "MountFuse"
        },
        "notes": "arpcfuse.Mount→arpcfs.MountFuse to avoid collision with arpcmount.Mount which also merges into arpcfs. Node type from arpcfuse is unexported in this context so no collision."
      },
      {
        "old_package": "internal/backend/vfs/arpcfs/arpcmount",
        "old_package_name": "arpcmount",
        "new_package": "internal/server/vfs/arpcfs",
        "new_package_name": "arpcfs",
        "files": [
          {
            "old_path": "internal/backend/vfs/arpcfs/arpcmount/mount.go",
            "new_path": "internal/server/vfs/arpcfs/arpcmount.go"
          }
        ],
        "symbol_renames": {
          "arpcmount.Mount": "MountARPC"
        },
        "notes": "arpcmount.Mount→arpcfs.MountARPC to avoid collision with arpcfuse.Mount which also merges into arpcfs."
      },
      {
        "old_package": "internal/backend/vfs/s3fs/fuse",
        "old_package_name": "fuse",
        "new_package": "internal/server/vfs/s3fs",
        "new_package_name": "s3fs",
        "files": [
          {
            "old_path": "internal/backend/vfs/s3fs/fuse/err.go",
            "new_path": "internal/server/vfs/s3fs/fuseErr.go"
          },
          {
            "old_path": "internal/backend/vfs/s3fs/fuse/server.go",
            "new_path": "internal/server/vfs/s3fs/fuseServer.go"
          }
        ],
        "symbol_renames": {
          "fuse.Mount": "MountFuse"
        },
        "notes": "fuse.Mount→s3fs.MountFuse to avoid collision with s3mount.Mount which also merges into s3fs. Node and FileHandle types from fuse have no collision with s3fs exports."
      },
      {
        "old_package": "internal/backend/vfs/s3fs/s3mount",
        "old_package_name": "s3mount",
        "new_package": "internal/server/vfs/s3fs",
        "new_package_name": "s3fs",
        "files": [
          {
            "old_path": "internal/backend/vfs/s3fs/s3mount/mount.go",
            "new_path": "internal/server/vfs/s3fs/s3mount.go"
          }
        ],
        "symbol_renames": {
          "s3mount.Mount": "MountS3"
        },
        "notes": "s3mount.Mount→s3fs.MountS3 to avoid collision with fuse.Mount→MountFuse."
      },
      {
        "old_package": "internal/backend/vfs/s3fs/s3url",
        "old_package_name": "s3url",
        "new_package": "internal/server/vfs/s3fs",
        "new_package_name": "s3fs",
        "files": [
          {
            "old_path": "internal/backend/vfs/s3fs/s3url/url.go",
            "new_path": "internal/server/vfs/s3fs/s3url.go"
          }
        ],
        "symbol_renames": {
          "s3url.Parse": "ParseS3Url"
        },
        "notes": "s3url.Parse→s3fs.ParseS3Url to avoid collision with generic name. S3Url struct becomes s3fs.S3Url."
      }
    ]
  },

